## Ignore Visual Studio temporary files, build results, and
## files generated by popular Visual Studio add-ons.

# User-specific files
*.rsuser
*.suo
*.user
*.userosscache
*.sln.docstates

# User-specific files (MonoDevelop/Xamarin Studio)
*.userprefs

# Build results
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Rr]eleases/
x64/
x86/
bld/
[Bb]in/
[Oo]bj/
[Ll]og/

# Visual Studio 2015/2017 cache/options directory
.vs/
# Uncomment if you use Visual Studio Code
# .vscode/

# MSTest test Results
[Tt]est[Rr]esult*/
[Bb]uild[Ll]og.*

# NUNIT
/*.VisualState.xml

# Build results of netfx-based projects
*.ncb
*.sdf
*.opensdf
*.osscache
*.pch
*.suo
*.user
*.userosscache
*.sln.docstates

# ReSharper is a popular add-on for Visual Studio
_ReSharper*/
*.[Rr]e[Ss]harper
*.DotSettings.user

# JustCode is a popular add-on for Visual Studio
.JustCode

# TeamCity is a popular CI server
_TeamCity*

# DotCover is a popular unit test coverage tool
*.dotCover

# AxoCover is a popular unit test coverage tool
.axoCover/*
!.axoCover/settings.json

# Visual Studio code coverage results
*.coverage
*.coveragexml

# MyGet package options
set-me-up.bat

# NCrunch
_NCrunch_*
.*crunch*.local.xml
nCrunchTemp_*

# MightyMoose
*.mm.*
AutoTest.Net/

# Web workbench (sass)
.sass-cache/

# Installshield output folder
[Ee]xpress/

# DocProject is a documentation generator add-on
DocProject/buildhelp/
DocProject/Help/*.mcgh

# Red Gate's SQL Toolbelt
*.sqlproj.user
*.query

# SQL Server files
App_Data/*.mdf
App_Data/*.ldf
App_Data/*.sdf

# Other temporary files
[Tt]mp/
[Tt]emp/
