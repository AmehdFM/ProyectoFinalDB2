using System;
using System.Data;
using System.Data.SqlClient;
using System.Drawing;
using System.Windows.Forms;
using System.Configuration;

namespace ProyectoFinalDB2
{
    public class SeccionProyectos : Form
    {
        private DataGridView dgvProyectos;
        private Label lblConteo;
        private string connStr = ConfigurationManager.ConnectionStrings["ConexionInversiones"]?.ConnectionString;

        private static readonly Color ColorFondo = Color.FromArgb(247, 247, 245);
        private static readonly Color ColorTarjeta = Color.White;
        private static readonly Color ColorBorde = Color.FromArgb(220, 220, 215);
        private static readonly Color ColorTexto = Color.FromArgb(30, 30, 28);
        private static readonly Color ColorTextoMuted = Color.FromArgb(130, 128, 120);
        private static readonly Color ColorPrimario = Color.FromArgb(26, 26, 46);
        private static readonly Color ColorSeleccion = Color.FromArgb(235, 244, 255);
        private static readonly Color ColorHeader = Color.FromArgb(250, 250, 248);

        public SeccionProyectos()
        {
            ConfigurarVista();
            CargarProyectos();
        }

        private void ConfigurarVista()
        {
            this.Text = "Portafolio de Proyectos — Inversiones Maya";
            this.Size = new Size(950, 600);
            this.StartPosition = FormStartPosition.CenterScreen;
            this.BackColor = ColorFondo;
            this.Font = new Font("Segoe UI", 9);

            // Breadcrumb
            Label lblBreadcrumb = new Label
            {
                Text = "Inversiones Maya  ›  Proyectos",
                Font = new Font("Segoe UI", 8),
                ForeColor = ColorTextoMuted,
                Location = new Point(28, 18),
                AutoSize = true
            };

            // Título
            Label lblTitulo = new Label
            {
                Text = "Proyectos Inmobiliarios",
                Font = new Font("Segoe UI", 15, FontStyle.Regular),
                ForeColor = ColorTexto,
                Location = new Point(28, 38),
                AutoSize = true
            };

            // Botón Nuevo
            Button btnNuevo = new Button
            {
                Text = "+  Crear nuevo proyecto",
                Location = new Point(720, 36),
                Size = new Size(190, 34),
                FlatStyle = FlatStyle.Flat,
                Font = new Font("Segoe UI", 9),
                BackColor = ColorPrimario,
                ForeColor = Color.White,
                Cursor = Cursors.Hand
            };
            btnNuevo.FlatAppearance.BorderSize = 0;
            btnNuevo.FlatAppearance.MouseOverBackColor = Color.FromArgb(40, 40, 70);
            btnNuevo.Click += (s, e) =>
            {
                using (var frm = new FormCrearProyecto())
                {
                    if (frm.ShowDialog() == DialogResult.OK) CargarProyectos();
                }
            };

            // Separador
            Panel pnlLinea = new Panel { Location = new Point(0, 86), Size = new Size(950, 1), BackColor = ColorBorde };

            // DataGridView
            dgvProyectos = new DataGridView
            {
                Location = new Point(0, 88),
                Size = new Size(920, 420),
                BackgroundColor = ColorTarjeta,
                BorderStyle = BorderStyle.None,
                AutoSizeColumnsMode = DataGridViewAutoSizeColumnsMode.Fill,
                SelectionMode = DataGridViewSelectionMode.FullRowSelect,
                AllowUserToAddRows = false,
                ReadOnly = true,
                RowHeadersVisible = false,
                GridColor = ColorBorde,
                CellBorderStyle = DataGridViewCellBorderStyle.SingleHorizontal,
                ColumnHeadersBorderStyle = DataGridViewHeaderBorderStyle.None,
                Font = new Font("Segoe UI", 9),
                RowTemplate = { Height = 44 }
            };

            dgvProyectos.ColumnHeadersDefaultCellStyle = new DataGridViewCellStyle
            {
                BackColor = ColorHeader,
                ForeColor = ColorTextoMuted,
                Font = new Font("Segoe UI", 8),
                Padding = new Padding(12, 0, 0, 0),
                SelectionBackColor = ColorHeader,
                SelectionForeColor = ColorTextoMuted
            };

            dgvProyectos.DefaultCellStyle = new DataGridViewCellStyle
            {
                BackColor = ColorTarjeta,
                ForeColor = ColorTexto,
                SelectionBackColor = ColorSeleccion,
                SelectionForeColor = ColorTexto,
                Padding = new Padding(12, 0, 0, 0)
            };

            dgvProyectos.CellContentClick += DgvProyectos_CellContentClick;

            // Footer
            Panel pnlFooter = new Panel { Location = new Point(0, 510), Size = new Size(920, 32), BackColor = ColorHeader };
            Panel pnlLineaFoot = new Panel { Dock = DockStyle.Top, Height = 1, BackColor = ColorBorde };
            lblConteo = new Label { Text = "", Font = new Font("Segoe UI", 8), ForeColor = ColorTextoMuted, Location = new Point(20, 9), AutoSize = true };
            pnlFooter.Controls.Add(pnlLineaFoot);
            pnlFooter.Controls.Add(lblConteo);

            this.Controls.Add(lblBreadcrumb);
            this.Controls.Add(lblTitulo);
            this.Controls.Add(btnNuevo);
            this.Controls.Add(pnlLinea);
            this.Controls.Add(dgvProyectos);
            this.Controls.Add(pnlFooter);

            this.Resize += (s, e) =>
            {
                int w = this.ClientSize.Width;
                dgvProyectos.Width = w - 30;
                pnlLinea.Width = w;
                pnlFooter.Width = w;
                btnNuevo.Left = w - btnNuevo.Width - 28;
            };
        }

        private void AgregarColumnas()
        {
            dgvProyectos.Columns.Clear();

            dgvProyectos.Columns.Add(new DataGridViewTextBoxColumn { Name = "Nombre", HeaderText = "PROYECTO", FillWeight = 40 });
            dgvProyectos.Columns.Add(new DataGridViewTextBoxColumn { Name = "Departamento", HeaderText = "DEPARTAMENTO", FillWeight = 20, DefaultCellStyle = { ForeColor = ColorTextoMuted } });
            dgvProyectos.Columns.Add(new DataGridViewTextBoxColumn { Name = "Municipio", HeaderText = "MUNICIPIO", FillWeight = 20, DefaultCellStyle = { ForeColor = ColorTextoMuted } });
            dgvProyectos.Columns.Add(new DataGridViewTextBoxColumn { Name = "Plazo", HeaderText = "PLAZO (MESES)", FillWeight = 20, DefaultCellStyle = { ForeColor = ColorTextoMuted } });

            var colEditar = new DataGridViewButtonColumn
            {
                Name = "BtnEditar",
                HeaderText = "",
                Text = "Editar",
                UseColumnTextForButtonValue = true,
                Width = 80,
                FlatStyle = FlatStyle.Flat
            };
            dgvProyectos.Columns.Add(colEditar);
        }

        private void DgvProyectos_CellContentClick(object sender, DataGridViewCellEventArgs e)
        {
            if (e.RowIndex < 0) return;
            if (dgvProyectos.Columns[e.ColumnIndex].Name != "BtnEditar") return;

            var row = dgvProyectos.Rows[e.RowIndex];
            if (!(row.Tag is int id)) return;

            string nombre = row.Cells["Nombre"].Value?.ToString();
            MessageBox.Show("Editar proyecto: " + nombre + " (ID=" + id + ")");
            // Aquí puedes abrir un formulario de edición si lo implementas.
        }

        private void CargarProyectos()
        {
            AgregarColumnas();

            try
            {
                if (string.IsNullOrEmpty(connStr)) { CargarDatosEjemplo(); return; }

                int count = 0;
                using (SqlConnection conn = new SqlConnection(connStr))
                using (SqlCommand cmd = conn.CreateCommand())
                {
                    cmd.CommandText = "SELECT ProyectoID, Nombre, Departamento, Municipio, PlazoMaximo FROM Proyecto ORDER BY Nombre";
                    conn.Open();

                    using (SqlDataReader reader = cmd.ExecuteReader())
                    {
                        while (reader.Read())
                        {
                            int idx = dgvProyectos.Rows.Add(
                                reader["Nombre"]?.ToString(),
                                reader["Departamento"]?.ToString(),
                                reader["Municipio"]?.ToString(),
                                reader["PlazoMaximo"]?.ToString()
                            );
                            dgvProyectos.Rows[idx].Tag = Convert.ToInt32(reader["ProyectoID"]);
                            count++;
                        }
                    }
                }

                lblConteo.Text = $"{count} proyecto{(count != 1 ? "s" : "")}";
            }
            catch
            {
                CargarDatosEjemplo();
            }
        }

        private void CargarDatosEjemplo()
        {
            int i1 = dgvProyectos.Rows.Add("Residencial Sol", "Quetzaltenango", "San Marcos", "36");
            dgvProyectos.Rows[i1].Tag = 1;
            int i2 = dgvProyectos.Rows.Add("Centro Maya", "Sacatepéquez", "Antigua", "48");
            dgvProyectos.Rows[i2].Tag = 2;

            lblConteo.Text = "2 proyectos (ejemplo)";
        }
    }
}