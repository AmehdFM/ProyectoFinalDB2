using System;
using System.Data;
using System.Data.SqlClient;
using System.Drawing;
using System.Windows.Forms;
using System.Configuration;

namespace ProyectoFinalDB2
{
    public class SeccionProyectos : Form
    {
        private DataGridView dgvProyectos;
        private string connStr = ConfigurationManager.ConnectionStrings["ConexionInversiones"]?.ConnectionString;

        public SeccionProyectos()
        {
            ConfigurarVista();
            CargarProyectos();
        }

        private void ConfigurarVista()
        {
            this.Text = "Portafolio de Proyectos — Inversiones Maya";
            this.Size = new Size(950, 600);
            this.StartPosition = FormStartPosition.CenterScreen;
            this.BackColor = Color.FromArgb(247, 247, 245);

            // Header con botón de Crear
            Panel pnlHeader = new Panel { Dock = DockStyle.Top, Height = 90, BackColor = Color.White };

            Label lblTit = new Label { Text = "Proyectos Inmobiliarios", Font = new Font("Segoe UI", 16, FontStyle.Bold), Location = new Point(25, 25), AutoSize = true };

            Button btnNuevo = new Button
            {
                Text = "+ Crear Nuevo Proyecto",
                Size = new Size(180, 35),
                Location = new Point(730, 25),
                BackColor = Color.FromArgb(26, 26, 46),
                ForeColor = Color.Black,
                FlatStyle = FlatStyle.Flat,
                Anchor = AnchorStyles.Top | AnchorStyles.Right,
                Cursor = Cursors.Hand
            };
            btnNuevo.FlatAppearance.BorderSize = 0;
            btnNuevo.Click += (s, e) =>
            {
                using (var frm = new FormCrearProyecto())
                {
                    if (frm.ShowDialog() == DialogResult.OK)
                    {
                        CargarProyectos();
                    }
                }
            };

            pnlHeader.Controls.AddRange(new Control[] { lblTit, btnNuevo });

            dgvProyectos = new DataGridView
            {
                Dock = DockStyle.Fill,
                BackgroundColor = Color.White,
                BorderStyle = BorderStyle.None,
                AutoSizeColumnsMode = DataGridViewAutoSizeColumnsMode.Fill,
                AllowUserToAddRows = false,
                RowHeadersVisible = false,
                SelectionMode = DataGridViewSelectionMode.FullRowSelect,
                RowTemplate = { Height = 45 }
            };

            this.Controls.Add(dgvProyectos);
            this.Controls.Add(pnlHeader);
        }

        private void CargarProyectos()
        {
            dgvProyectos.Columns.Clear();
            using (SqlConnection conn = new SqlConnection(connStr))
            {
                // El ID se trae pero se oculta después
                string sql = "SELECT ProyectoID, Nombre, Departamento, Municipio, PlazoMaximo FROM Proyecto";
                SqlDataAdapter da = new SqlDataAdapter(sql, conn);
                DataTable dt = new DataTable();
                da.Fill(dt);
                dgvProyectos.DataSource = dt;
            }

            // Ocultar el ID para que el usuario no lo vea
            if (dgvProyectos.Columns.Contains("ProyectoID")) dgvProyectos.Columns["ProyectoID"].Visible = false;

            // Agregar botón de "Ver Detalle"
            var colVer = new DataGridViewButtonColumn
            {
                Name = "BtnVer",
                HeaderText = "ACCIÓN",
                Text = "Ver Proyecto",
                UseColumnTextForButtonValue = true,
                FlatStyle = FlatStyle.Flat,
                Width = 100
            };
            dgvProyectos.Columns.Add(colVer);
            dgvProyectos.CellContentClick += (s, e) => {
                if (e.RowIndex >= 0 && dgvProyectos.Columns[e.ColumnIndex].Name == "BtnVer")
                {
                    int id = (int)dgvProyectos.Rows[e.RowIndex].Cells["ProyectoID"].Value;
                    string nombre = dgvProyectos.Rows[e.RowIndex].Cells["Nombre"].Value.ToString();
                    // Aquí abrirías la página de detalles
                    MessageBox.Show("Navegando a los detalles de: " + nombre);
                }
            };
        }
    }
}