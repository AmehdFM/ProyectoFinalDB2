using System;
using System.Drawing;
using System.Windows.Forms;

namespace ProyectoFinalDB2
{
    public class PanelPrincipal : Form
    {
        public PanelPrincipal()
        {
            ConfigurarPanel();
        }

        private void ConfigurarPanel()
        {
            // --- CONFIGURACIÓN DE VENTANA ---
            this.Text = "Inversiones Maya - Dashboard";
            this.Size = new Size(1100, 700);
            this.StartPosition = FormStartPosition.CenterScreen;
            this.BackColor = Color.FromArgb(240, 242, 245); // Gris claro moderno
            this.Font = new Font("Segoe UI", 10);

            // --- PANEL LATERAL (NAV) ---
            Panel pnlLateral = new Panel
            {
                Dock = DockStyle.Left,
                Width = 250,
                BackColor = Color.FromArgb(44, 62, 80), // Azul oscuro
                Padding = new Padding(0, 20, 0, 0)
            };

            // Botones del Menú Lateral
            pnlLateral.Controls.Add(CrearBotonLateral("PROYECTOS", 200, Color.Transparent));
            pnlLateral.Controls.Add(CrearBotonLateral("EMPLEADOS", 140, Color.Transparent));
            pnlLateral.Controls.Add(CrearBotonLateral("FINANCIERO", 80, Color.Transparent));

            // --- HEADER ---
            Panel pnlHeader = new Panel
            {
                Dock = DockStyle.Top,
                Height = 80,
                BackColor = Color.White
            };

            Label lblSaludo = new Label
            {
                Text = "BIENVENIDO AL SISTEMA",
                Font = new Font("Segoe UI", 18, FontStyle.Bold),
                ForeColor = Color.FromArgb(52, 73, 94),
                Location = new Point(30, 22),
                AutoSize = true
            };
            pnlHeader.Controls.Add(lblSaludo);

            // --- CONTENEDOR CENTRAL (TARJETAS) ---
            FlowLayoutPanel pnlCentral = new FlowLayoutPanel
            {
                Dock = DockStyle.Fill,
                Padding = new Padding(30),
                AutoScroll = true
            };

            // Agregamos tarjetas visuales informativas
            pnlCentral.Controls.Add(CrearTarjetaInfo("Proyectos Activos", "12", Color.FromArgb(52, 152, 219)));
            pnlCentral.Controls.Add(CrearTarjetaInfo("Total Empleados", "45", Color.FromArgb(0, 184, 148)));
            pnlCentral.Controls.Add(CrearTarjetaInfo("Ingresos Mes", "$24,500", Color.FromArgb(230, 126, 34)));

            // Agregar controles al Form principal
            this.Controls.Add(pnlCentral);
            this.Controls.Add(pnlHeader);
            this.Controls.Add(pnlLateral);
        }

        private Button CrearBotonLateral(string texto, int yPos, Color color)
        {
            Button btn = new Button
            {
                Text = "  " + texto,
                Size = new Size(250, 55),
                Location = new Point(0, yPos),
                FlatStyle = FlatStyle.Flat,
                ForeColor = Color.FromArgb(189, 195, 199),
                Font = new Font("Segoe UI", 10, FontStyle.Bold),
                TextAlign = ContentAlignment.MiddleLeft,
                Cursor = Cursors.Hand,
                Dock = DockStyle.Top // Los apilamos arriba
            };
            btn.FlatAppearance.BorderSize = 0;
            btn.FlatAppearance.MouseOverBackColor = Color.FromArgb(52, 73, 94);

            btn.Click += (s, e) => {
                if (texto == "EMPLEADOS")
                {
                    SeccionEmpleados seccion = new SeccionEmpleados();
                    seccion.ShowDialog();
                }
                else
                {
                    MessageBox.Show("Abriendo sección de " + texto);
                }
            };

            return btn;
        }

        private Panel CrearTarjetaInfo(string titulo, string valor, Color colorAccent)
        {
            Panel card = new Panel
            {
                Size = new Size(250, 130),
                BackColor = Color.White,
                Margin = new Padding(10)
            };

            // Línea de color superior
            Panel line = new Panel
            {
                BackColor = colorAccent,
                Height = 5,
                Dock = DockStyle.Top
            };

            Label lblT = new Label
            {
                Text = titulo,
                Font = new Font("Segoe UI", 10),
                ForeColor = Color.Gray,
                Location = new Point(15, 25),
                AutoSize = true
            };

            Label lblV = new Label
            {
                Text = valor,
                Font = new Font("Segoe UI", 20, FontStyle.Bold),
                ForeColor = Color.Black,
                Location = new Point(15, 55),
                AutoSize = true
            };

            card.Controls.AddRange(new Control[] { line, lblT, lblV });
            return card;
        }

        protected override void OnFormClosing(FormClosingEventArgs e)
        {
            base.OnFormClosing(e);
            Application.Exit();
        }
    }
}